{
  "name": "git-change-highlighter",
  "displayName": "Git Change Highlighter",
  "publisher": "Piyush5784",
  "description": "Cursor-style line highlighting for git changes: highlights every changed line and lets you step through, accept, or reject each one.",
  "version": "0.0.5",
  "repository": {
    "type": "git",
    "url": "https://github.com/Piyush5784/Cusor-Style-Line-Highlighter.git"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "extensionDependencies": [
    "vscode.git"
  ],
  "contributes": {
    "commands": [
      {
        "command": "gitChangeHighlighter.nextChange",
        "title": "Git Change Highlighter: Next Change"
      },
      {
        "command": "gitChangeHighlighter.previousChange",
        "title": "Git Change Highlighter: Previous Change"
      },
      {
        "command": "gitChangeHighlighter.refresh",
        "title": "Git Change Highlighter: Refresh"
      }
    ],
    "keybindings": [
      {
        "command": "gitChangeHighlighter.nextChange",
        "key": "ctrl+alt+n",
        "when": "editorTextFocus"
      },
      {
        "command": "gitChangeHighlighter.previousChange",
        "key": "ctrl+alt+p",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.125.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.25.10",
    "eslint": "^9.36.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  }
}